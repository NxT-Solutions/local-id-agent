{
  "server": {
    "host": "127.0.0.1",
    "port": 17443,
    "dev_mode": true
  },
  "security": {
    "allowed_origins": [
      "https://app.example.com",
      "http://localhost:5173",
      "http://localhost:5174"
    ],
    "allowed_backends": [
      "https://api.example.com",
      "http://localhost:8000"
    ],
    "challenge_max_age_seconds": 60
  },
  "providers": {
    "default": "mock",
    "mock": {
      "enabled": true
    },
    "pkcs11": {
      "enabled": false,
      "module_path": "auto",
      "token_label": "",
      "certificate_label": "",
      "pin_prompt": "terminal"
    },
    "belgian_eid": {
      "enabled": false,
      "pkcs11_module_path": "auto"
    }
  },
  "logging": {
    "level": "info"
  }
}
