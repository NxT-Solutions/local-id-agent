{
  "name": "@rqc-icu/localid-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "generate:api": "orval --config orval.config.ts"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.10.2",
    "@vitest/coverage-v8": "^4.1.8",
    "orval": "^7.17.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
