{
  "server": {
    "host": "127.0.0.1",
    "port": 17443,
    "dev_mode": true
  },
  "security": {
    "allowed_origins": [
      "tauri://localhost",
      "http://localhost:1420",
      "http://localhost:5173",
      "https://app.example.com"
    ],
    "allowed_backends": [
      "http://localhost:8000",
      "https://api.example.com"
    ],
    "challenge_max_age_seconds": 60
  },
  "providers": {
    "default": "belgian_eid",
    "mock": {
      "enabled": true
    },
    "pkcs11": {
      "enabled": false,
      "module_path": "auto",
      "token_label": "",
      "certificate_label": "",
      "pin_prompt": "terminal"
    },
    "belgian_eid": {
      "enabled": true,
      "pkcs11_module_path": "auto"
    }
  },
  "logging": {
    "level": "info"
  }
}
